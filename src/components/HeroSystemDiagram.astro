<style>
  @keyframes hero-diagram-dash {
    to {
      stroke-dashoffset: -42;
    }
  }

  .hero-diagram-flow-spine {
    stroke-dasharray: 10 8;
    animation: hero-diagram-dash 3.5s linear infinite;
  }

  .hero-diagram-flow-spine-m {
    stroke-dasharray: 9 8;
    animation: hero-diagram-dash 3.5s linear infinite;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-diagram-flow-spine,
    .hero-diagram-flow-spine-m {
      animation: none;
      stroke-dasharray: none;
    }
  }
</style>
