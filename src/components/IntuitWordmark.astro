---
import wordmarkMeta from '../brand/logo-wordmark-meta.json';

interface Props {
  variant: 'light' | 'dark';
  alt: string;
  /** Kai true — `alt=""` ir `aria-hidden` (dekoratyvus blokas ant tamsaus fono). */
  decorative?: boolean;
  class?: string;
  /** Tailwind ant `<img>` (aukštis valdo wordmark plotį). */
  imgClass?: string;
  loading?: 'eager' | 'lazy';
  fetchpriority?: 'high' | 'low' | 'auto';
}

const {
  variant,
  alt,
  decorative = false,
  class: className,
  imgClass = 'h-10 w-auto md:h-11',
  loading = 'lazy',
  fetchpriority,
} = Astro.props;

const basePath = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const meta = variant === 'light' ? wordmarkMeta.logoWordmarkLight : wordmarkMeta.logoWordmarkDark;
const stem = variant === 'light' ? 'logo-wordmark-light' : 'logo-wordmark-dark';
const webpSrc = `${basePath}brand/${stem}.webp`;
const jpgSrc = `${basePath}brand/${stem}.jpg`;
/** Light UI: PNG su alpha (šriftas ant permatomo — nesikerta su `bg-warm` / `bg-paper`). Dark: JPG fallback. */
const rasterFallbackSrc =
  variant === 'light' ? `${basePath}brand/${stem}.png` : jpgSrc;
---

<picture class:list={[className]}>
  <source srcset={webpSrc} type="image/webp" />
  <img
    src={rasterFallbackSrc}
    width={meta.width}
    height={meta.height}
    alt={decorative ? '' : alt}
    aria-hidden={decorative ? 'true' : undefined}
    class:list={[imgClass, 'max-w-none object-contain object-left']}
    loading={loading}
    decoding="async"
    fetchpriority={fetchpriority}
  />
</picture>
