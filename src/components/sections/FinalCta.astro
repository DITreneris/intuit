---
import ButtonPrimary from '../ui/ButtonPrimary.astro';
import IntuitWordmark from '../IntuitWordmark.astro';
import type { SiteMessages } from '../../i18n/types';

interface Props {
  messages: SiteMessages;
}

const { messages } = Astro.props;

const basePath = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const email =
  (import.meta.env.PUBLIC_CONTACT_EMAIL as string | undefined)?.trim() ||
  messages.finalCta.contactEmail;
const params = new URLSearchParams();
params.set('subject', messages.finalCta.cta);
params.set('body', messages.finalCta.mailBodyTemplate);
const mailHref = `mailto:${email}?${params.toString()}`;

const telHref = `tel:${messages.finalCta.contactPhone.replace(/\s+/g, '')}`;
const mapsHref = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(messages.finalCta.addressLine)}`;
---

<section id="contact" class="scroll-mt-28 bg-ink text-white">
  <div class="section-shell space-y-10">
    <div class="grid gap-10 md:grid-cols-[1.2fr_0.8fr] md:items-start">
      <div class="space-y-4">
        <h2 class="text-3xl font-semibold tracking-tight md:text-4xl">{messages.finalCta.title}</h2>
        <p class="max-w-measure text-lg text-white/70">{messages.finalCta.subtitle}</p>
      </div>

      <div class="rounded-xl border border-white/15 bg-white/10 p-6 backdrop-blur">
        <div class="mb-6 flex flex-col gap-5 sm:flex-row sm:items-start">
          <div
            class="relative mx-auto h-28 w-28 shrink-0 overflow-hidden rounded-xl ring-1 ring-white/20 sm:mx-0 md:h-32 md:w-32"
          >
            <picture class="block h-full w-full">
              <source srcset={`${basePath}brand/contact-nerijus.webp`} type="image/webp" />
              <img
                src={`${basePath}brand/contact-nerijus.jpg`}
                alt={messages.finalCta.contactPhotoAlt}
                width="480"
                height="480"
                class="h-full w-full origin-[72%_38%] scale-[1.2] object-cover"
                loading="lazy"
                decoding="async"
              />
            </picture>
          </div>

          <div class="min-w-0 flex-1 space-y-4">
            <IntuitWordmark
              variant="dark"
              alt=""
              decorative
              imgClass="h-11 w-auto opacity-95 md:h-12"
              loading="lazy"
            />

            <p class="text-xs font-medium uppercase tracking-wide text-white/55">
              {messages.finalCta.companyName}
            </p>

            <div class="space-y-2 text-sm">
              <p class="font-semibold text-white">
                {messages.finalCta.contactName}
                <span class="font-normal text-white/65"> · {messages.finalCta.contactRole}</span>
              </p>
              <a
                href={mapsHref}
                target="_blank"
                rel="noopener noreferrer"
                class="block text-white/75 underline-offset-2 transition hover:text-white hover:underline"
              >
                {messages.finalCta.addressLine}
              </a>
              <a
                href={telHref}
                class="block text-white/75 underline-offset-2 transition hover:text-white hover:underline"
              >
                {messages.finalCta.contactPhone}
              </a>
              <a
                href={mailHref}
                class="block text-white/75 underline-offset-2 transition hover:text-white hover:underline"
              >
                {email}
              </a>
            </div>
          </div>
        </div>

        <ButtonPrimary href={mailHref} variant="onDark" class="w-full">
          {messages.finalCta.cta}
        </ButtonPrimary>
      </div>
    </div>
  </div>
</section>
