---
import type { SiteMessages } from '../../i18n/types';

interface Props {
  messages: SiteMessages;
}

const { messages } = Astro.props;

/** Inline signal ikonos (be išorinės icon lib) — vienodas 24×24 viewBox */
const icons = [
  // 0 — fragmentai / atšakos
  `<path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" d="M5 12h6M13 12h6M9 5v14" />`,
  // 1 — zigzag / reakcija
  `<path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M4 18 8 6l4 8 4-8 4 12" />`,
  // 2 — atskirti keliai
  `<path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" d="M12 4v16M8 8l-4 4 4 4M16 8l4 4-4 4" />`,
  // 3 — sluoksniai be proceso
  `<rect x="4" y="5" width="16" height="4" rx="1" fill="none" stroke="currentColor" stroke-width="2"/><rect x="4" y="10" width="10" height="4" rx="1" fill="none" stroke="currentColor" stroke-width="2"/><rect x="4" y="15" width="16" height="4" rx="1" fill="none" stroke="currentColor" stroke-width="2"/>`,
] as const;
---

<section id="problem" class="scroll-mt-28 border-b border-line bg-surface">
  <div class="mx-auto max-w-content space-y-8 px-4 py-16 md:px-6 md:py-20">
    <div class="max-w-3xl space-y-4">
      <h2 class="text-3xl font-semibold tracking-tight md:text-4xl">{messages.problem.title}</h2>
      <p class="text-muted">{messages.problem.caption}</p>
    </div>
    <ul class="grid gap-4 md:grid-cols-2">
      {
        messages.problem.bullets.map((item, idx) => {
          const isFeatured = idx === 0;
          const liClass = isFeatured
            ? 'relative overflow-hidden rounded-xl border border-danger/25 bg-paper px-5 py-6 shadow-soft ring-1 ring-danger/10 md:-translate-y-0.5'
            : 'card-muted px-5 py-6';
          return (
            <li class:list={[liClass, 'flex flex-col gap-4']}>
              <span
                class:list={[
                  'flex h-12 w-12 shrink-0 items-center justify-center rounded-xl border',
                  isFeatured ? 'border-danger/25 bg-dangerSoft text-danger' : 'border-line bg-surface text-muted',
                ]}
                aria-hidden="true"
              >
                <svg class="h-6 w-6" viewBox="0 0 24 24" aria-hidden="true" set:html={icons[idx] ?? icons[0]} />
              </span>
              <div class="min-w-0 space-y-2">
                <p class:list={['text-base font-semibold leading-snug', isFeatured ? 'text-danger' : 'text-ink']}>
                  {item.signal}
                </p>
                <p class="text-sm leading-relaxed text-muted">{item.detail}</p>
              </div>
            </li>
          );
        })
      }
    </ul>
  </div>
</section>
