---
import type { SiteMessages } from '../../i18n/types';

interface Props {
  messages: SiteMessages;
}

const { messages } = Astro.props;

const aboutIcons = [
  `<path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4" fill="none" stroke="currentColor" stroke-width="2"/><path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/>`,
  `<rect x="2" y="7" width="20" height="14" rx="2" fill="none" stroke="currentColor" stroke-width="2"/><path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>`,
] as const;
---

<section id="about" class="scroll-mt-28 border-b border-line bg-paper">
  <div class="mx-auto max-w-content space-y-8 px-4 py-16 md:px-6 md:py-20">
    <h2 class="text-3xl font-semibold tracking-tight md:text-4xl">{messages.about.title}</h2>
    <div class="grid gap-8 md:grid-cols-2">
      {messages.about.paragraphs.map((p, idx) => (
        <div class="flex flex-col gap-4">
          <span
            class="flex h-12 w-12 items-center justify-center rounded-xl border border-accent/15 bg-accent/5 text-accent"
            aria-hidden="true"
          >
            <svg class="h-6 w-6" viewBox="0 0 24 24" set:html={aboutIcons[idx] ?? aboutIcons[0]} />
          </span>
          <p class="text-sm leading-relaxed text-muted md:text-base">{p}</p>
        </div>
      ))}
    </div>
  </div>
</section>
