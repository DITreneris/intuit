---
import ButtonPrimary from '../ui/ButtonPrimary.astro';
import ButtonSecondary from '../ui/ButtonSecondary.astro';
import type { SiteMessages } from '../../i18n/types';

interface Props {
  messages: SiteMessages;
}

const { messages } = Astro.props;

const isHighlighted = (tier: (typeof messages.offers.tiers)[number]) =>
  'highlighted' in tier && tier.highlighted === true;
---

<section id="offers" class="scroll-mt-28 border-b border-line bg-surface">
  <div class="section-shell space-y-10 md:space-y-12">
    <div class="max-w-measure space-y-4">
      <h2 class="text-3xl font-semibold tracking-tight md:text-4xl">{messages.offers.title}</h2>
      <div class="h-px w-12 bg-accent/20" aria-hidden="true"></div>
      <p class="section-intro">{messages.offers.subtitle}</p>
    </div>

    <div class="grid gap-6 md:grid-cols-3">
      {messages.offers.tiers.map((tier) => (
        <article
          class:list={[
            isHighlighted(tier) ? 'card-featured card-brand' : 'card card-brand flex flex-col p-6',
          ]}
        >
          <div class="border-b border-line/80 pb-5">
            <div class="flex items-start justify-between gap-3">
              <div>
                <h3 class="card-title">{tier.name}</h3>
                <p class="mt-1 text-sm font-medium text-muted">{tier.tag}</p>
              </div>
              <span
                class="shrink-0 rounded-md border border-line/70 bg-paper px-1.5 py-0.5 text-2xs font-medium tabular-nums text-muted"
              >
                {tier.price}
              </span>
            </div>
          </div>
          <ul class="mt-8 flex-1 space-y-3.5 text-base leading-relaxed">
            {tier.bullets.map((b) => (
              <li class="flex gap-2">
                <span class="mt-0.5 shrink-0 text-accent" aria-hidden="true">✓</span>
                <span>{b}</span>
              </li>
            ))}
          </ul>
          {isHighlighted(tier) ? (
            <ButtonPrimary href="#contact" class="mt-8 w-full shrink-0">
              {tier.cta}
            </ButtonPrimary>
          ) : (
            <ButtonSecondary href="#contact" class="mt-8 w-full shrink-0">
              {tier.cta}
            </ButtonSecondary>
          )}
        </article>
      ))}
    </div>
  </div>
</section>
