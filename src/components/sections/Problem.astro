---
import type { SiteMessages } from '../../i18n/types';

interface Props {
  messages: SiteMessages;
}

const { messages } = Astro.props;
---

<section id="problem" class="scroll-mt-28 border-b border-line bg-surface">
  <div class="mx-auto max-w-content space-y-8 px-4 py-16 md:px-6 md:py-20">
    <div class="max-w-3xl space-y-4">
      <h2 class="text-3xl font-semibold tracking-tight md:text-4xl">{messages.problem.title}</h2>
      <p class="text-muted">{messages.problem.caption}</p>
    </div>
    <ul class="grid gap-4 md:grid-cols-2">
      {messages.problem.bullets.map((item) => (
        <li class="card-muted px-5 py-4 text-sm leading-relaxed text-ink">
          {item}
        </li>
      ))}
    </ul>
  </div>
</section>
