<style>
  .hsd-stage {
    position: relative;
  }
  .hsd-stage--desktop {
    aspect-ratio: 612 / 200;
  }
  .hsd-stage--mobile {
    aspect-ratio: 300 / 412;
  }
  .hsd-stage > svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .hsd-connectors {
    pointer-events: none;
  }

  .hsd-connector {
    position: absolute;
    background: var(--ds-accent);
    border-radius: 2px;
    opacity: 0.55;
  }

  /* Horizontal connector (desktop) */
  .hsd-connectors:not(.hsd-connectors--vertical) .hsd-connector {
    left: var(--cx-start);
    right: calc(100% - var(--cx-end));
    top: var(--cy);
    height: 1.5px;
    transform: translateY(-50%);
  }

  /* Vertical connector (mobile) */
  .hsd-connectors--vertical .hsd-connector {
    top: var(--cy-start);
    bottom: calc(100% - var(--cy-end));
    left: var(--cx);
    width: 1.5px;
    transform: translateX(-50%);
  }

  /* Chevron — horizontal (rotate 45°: kampas rodo į dešinę) */
  .hsd-connectors[data-variant='chevron']:not(.hsd-connectors--vertical) .hsd-connector::after {
    content: '';
    position: absolute;
    right: 0;
    top: 50%;
    width: 6px;
    height: 6px;
    border-top: 1.5px solid var(--ds-accent);
    border-right: 1.5px solid var(--ds-accent);
    transform: translate(1px, -50%) rotate(45deg);
  }

  /* Chevron — vertical (rotate 135°: kampas rodo žemyn) */
  .hsd-connectors--vertical[data-variant='chevron'] .hsd-connector::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    width: 6px;
    height: 6px;
    border-top: 1.5px solid var(--ds-accent);
    border-right: 1.5px solid var(--ds-accent);
    transform: translate(-50%, 1px) rotate(135deg);
  }

  /* Line variant — be galvutės (kryptis per kortelių numerius 1–4) */
  .hsd-connectors[data-variant='line'] .hsd-connector::after {
    content: none;
  }
</style>
