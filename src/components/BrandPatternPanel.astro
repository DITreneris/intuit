---
/**
 * Inverse ženklas + raštas (`logo-pattern-inverse`) ant gradientinio Hero fono.
 * `alt` iš `messages.proof.brandPatternAlt`.
 */
import type { SiteMessages } from '../i18n/types';

interface Props {
  messages: SiteMessages;
}

const { messages } = Astro.props;

const basePath = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<div
  class="overflow-hidden rounded-2xl bg-gradient-to-b from-heroInkFrom to-heroInkTo shadow-[inset_0_1px_0_0_rgba(255,255,255,0.06)] ring-1 ring-white/10"
>
  <div class="relative">
    <img
      src={`${basePath}brand/logo-pattern-inverse.jpg`}
      alt={messages.proof.brandPatternAlt}
      class="relative z-0 block h-auto w-full"
      width={1000}
      height={978}
      fetchpriority="high"
      loading="eager"
      decoding="async"
    />
    <!-- Nutildo apatinį chevron raštą (tekstūra, ne kilimas); ženklas aukščiau lieka aiškus -->
    <div
      class="pointer-events-none absolute inset-x-0 bottom-0 z-10 h-[52%] bg-gradient-to-t from-heroInkTo via-heroInkTo/75 to-transparent"
      aria-hidden="true"
    />
  </div>
</div>
