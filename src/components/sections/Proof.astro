---
import type { SiteMessages } from '../../i18n/types';

interface Props {
  messages: SiteMessages;
}

const { messages } = Astro.props;

const metricIcons = [
  `<path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M1 12s4-7 11-7 11 7 11 7-4 7-11 7-11-7-11-7z"/><circle cx="12" cy="12" r="3" fill="none" stroke="currentColor" stroke-width="2"/>`,
  `<path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>`,
  `<path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>`,
] as const;
---

<section id="proof" class="scroll-mt-28 border-b border-line bg-paper">
  <div class="mx-auto max-w-content space-y-10 px-4 py-16 md:px-6 md:py-20">
    <div class="max-w-3xl space-y-4">
      <h2 class="text-3xl font-semibold tracking-tight md:text-4xl">{messages.proof.title}</h2>
      <p class="text-base text-muted md:text-lg">{messages.proof.body}</p>
    </div>

    <div class="grid gap-4 md:grid-cols-3">
      {messages.proof.metrics.map((m, idx) => (
        <div class="card-muted flex flex-col gap-4 p-6">
          <span
            class="flex h-11 w-11 items-center justify-center rounded-xl border border-accent/15 bg-accent/5 text-accent"
            aria-hidden="true"
          >
            <svg class="h-5 w-5" viewBox="0 0 24 24" set:html={metricIcons[idx] ?? metricIcons[0]} />
          </span>
          <div>
            <div class="flex items-baseline gap-2">
              <span class="text-3xl font-semibold text-ink">{m.value}</span>
              <span class="text-sm font-medium text-muted">{m.label}</span>
            </div>
            <p class="mt-2 text-sm text-muted">{m.hint}</p>
          </div>
        </div>
      ))}
    </div>

    <div class="rounded-xl border border-dashed border-accent/25 bg-aiSoft/40 p-6 md:p-8">
      <div class="flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
        <div>
          <p class="text-xs font-semibold uppercase tracking-wide text-muted">{messages.proof.demoLabel}</p>
          <p class="mt-2 max-w-2xl text-sm leading-relaxed text-muted">{messages.proof.demoNote}</p>
        </div>
        <div class="rounded-lg bg-surface px-4 py-3 text-xs font-medium text-muted shadow-inner">
          {messages.proof.metricsIntro}
        </div>
      </div>
    </div>
  </div>
</section>
