  .hero-diagram-flow-baseline {
    stroke-dasharray: 8 6;
    animation: hero-diagram-dash 3.5s linear infinite;
  }

  .hero-diagram-flow-baseline-m {
    stroke-dasharray: 7 6;
    animation: hero-diagram-dash 3.5s linear infinite;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-diagram-flow-baseline,
    .hero-diagram-flow-baseline-m {
      animation: none;
      stroke-dasharray: none;
    }
  }
</style>
