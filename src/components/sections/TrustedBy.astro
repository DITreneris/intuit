---
import IntuitWordmark from '../IntuitWordmark.astro';
import type { SiteMessages } from '../../i18n/types';

interface Props {
  messages: SiteMessages;
}

const { messages } = Astro.props;
const t = messages.trustedBy;
const showHint = t.hint.trim() !== '';

const basePath = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<section
  id="clients"
  aria-labelledby="trusted-by-heading"
  class="scroll-mt-28 border-b border-line bg-paper"
>
  <div class="section-shell--tight">
    <div class="mb-6 text-center">
      <h2
        id="trusted-by-heading"
        class="label-eyebrow flex flex-wrap items-center justify-center gap-x-2 gap-y-1"
      >
        <span>{t.titleBefore}</span>
        <IntuitWordmark
          variant="light"
          alt={messages.hero.logoAlt}
          imgClass="h-10 w-auto shrink-0 md:h-11"
          loading="lazy"
        />
      </h2>
      {
        showHint ? (
          <p class="mt-2 text-xs text-muted/90">{t.hint}</p>
        ) : null
      }
    </div>

    <ul
      class="grid grid-cols-2 gap-6 sm:grid-cols-3 md:grid-cols-4"
      aria-label={t.logosRegionAriaLabel}
    >
      {
        t.logos.map((logo) => (
          <li class="group flex items-center justify-center">
            <div class="flex h-16 w-40 max-w-full shrink-0 items-center justify-center rounded-xl border border-line/60 bg-surface/40 px-2">
              <img
                src={`${basePath}${logo.src}`}
                alt={logo.alt}
                class="max-h-10 w-auto max-w-full object-contain object-center opacity-[0.88] grayscale transition-[filter,opacity] duration-150 group-hover:opacity-100 group-hover:grayscale-0"
                width="220"
                height="88"
                loading="lazy"
                decoding="async"
              />
            </div>
          </li>
        ))
      }
    </ul>
  </div>
</section>
