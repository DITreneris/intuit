---
import '../styles/global.css';
import type { SiteMessages } from '../i18n/types';
import Analytics from '@vercel/analytics/astro';

interface Props {
  messages: SiteMessages;
  lang: 'lt' | 'en';
}

const { messages, lang } = Astro.props;
const siteBase = Astro.site ?? new URL('https://www.intuit.lt');
/** Astro `base` be trailing slash → santykiniai keliai suliptų (pvz. `/intuitbrand`); visada `/kelias/` */
const basePath = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const baseRoot = new URL(basePath, siteBase);
const canonicalURL = new URL(Astro.url.pathname + Astro.url.search, siteBase);
const ogImage =
  lang === 'lt'
    ? new URL('social/og-lt.jpg', baseRoot).href
    : new URL('social/og-en.jpg', baseRoot).href;
const ogImageAlt = messages.meta.ogImageAlt;
const hrefLt = baseRoot.href;
const hrefEn = new URL('en/', baseRoot).href;
const faviconHref = new URL('favicon.svg', baseRoot).pathname;
const faviconPngHref = new URL('favicon-32x32.png', baseRoot).pathname;
const appleTouchIconHref = new URL('apple-touch-icon.png', baseRoot).pathname;
const sitemapHref = new URL('sitemap.xml', baseRoot).href;

const orgId = `${baseRoot.href}#organization`;
const websiteId = `${baseRoot.href}#website`;
const webpageId = `${canonicalURL.href}#webpage`;

const addressLine = messages.finalCta.addressLine;
const addressParts = addressLine.split(',').map((p) => p.trim()).filter(Boolean);
const streetAddress = addressParts[0] ?? addressLine;
const localityPostal = addressParts.slice(1).join(', ');
const postalMatch = localityPostal.match(/\bLT-\d{5}\b/);
const postalCode = postalMatch?.[0];
const addressLocality = localityPostal.replace(/\bLT-\d{5}\b/, '').trim() || undefined;

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': orgId,
      name: messages.finalCta.companyName,
      url: baseRoot.href,
      email: messages.finalCta.contactEmail,
      telephone: messages.finalCta.contactPhone,
      address: {
        '@type': 'PostalAddress',
        streetAddress,
        postalCode,
        addressLocality,
        addressCountry: 'LT',
      },
    },
    {
      '@type': 'WebSite',
      '@id': websiteId,
      url: baseRoot.href,
      name: messages.nav.brand,
      inLanguage: lang,
      publisher: { '@id': orgId },
    },
    {
      '@type': 'WebPage',
      '@id': webpageId,
      url: canonicalURL.href,
      name: messages.meta.title,
      description: messages.meta.description,
      inLanguage: lang,
      isPartOf: { '@id': websiteId },
      about: { '@id': orgId },
    },
  ],
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={faviconHref} />
    <link rel="icon" type="image/png" sizes="32x32" href={faviconPngHref} />
    <link rel="apple-touch-icon" href={appleTouchIconHref} />
    <meta name="generator" content={Astro.generator} />
    <title>{messages.meta.title}</title>
    <meta name="description" content={messages.meta.description} />
    <link rel="canonical" href={canonicalURL.href} />
    <link rel="alternate" hreflang="lt" href={hrefLt} />
    <link rel="alternate" hreflang="en" href={hrefEn} />
    <link rel="alternate" hreflang="x-default" href={hrefLt} />
    <link rel="sitemap" type="application/xml" title="Sitemap" href={sitemapHref} />
    <meta property="og:site_name" content="INTUIT" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={messages.meta.title} />
    <meta property="og:description" content={messages.meta.description} />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta property="og:locale" content={messages.meta.ogLocale} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={messages.meta.title} />
    <meta name="twitter:description" content={messages.meta.description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={ogImageAlt} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body class="min-h-dvh bg-warm text-ink">
    <a class="skip-to-main" href="#main">{messages.a11y.skipToMain}</a>
    <slot />
    <Analytics />
  </body>
</html>
