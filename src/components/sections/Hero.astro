---
import HeroSystemDiagram from '../HeroSystemDiagram.astro';
import ButtonPrimary from '../ui/ButtonPrimary.astro';
import ButtonSecondary from '../ui/ButtonSecondary.astro';
import type { SiteMessages } from '../../i18n/types';

interface Props {
  messages: SiteMessages;
}

const { messages } = Astro.props;

const basePath = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const patternLightUrl = `${basePath}brand/logo-pattern-light.jpg`;
---

<section id="hero" class="relative scroll-mt-28 overflow-hidden border-b border-line bg-hero-premium">
  <div
    class="pointer-events-none absolute -right-10 top-0 h-full w-[min(72vw,22rem)] bg-cover bg-[0%_50%] opacity-[0.04] mix-blend-multiply md:-right-14 md:w-[min(52vw,30rem)] md:opacity-[0.055]"
    style={`background-image: url('${patternLightUrl}')`}
    aria-hidden="true"
  />
  <div
    class="section-shell relative grid gap-10 md:grid-cols-[minmax(0,0.95fr)_minmax(0,1.12fr)] md:items-center md:gap-12"
  >
    <div class="order-2 space-y-6 md:order-1">
      <p class="label-eyebrow">{messages.hero.eyebrow}</p>
      <h1 class="text-balance text-4xl font-semibold leading-tight tracking-tight md:text-5xl">
        {messages.hero.title}
      </h1>
      <p class="max-w-measure text-lg text-muted">{messages.hero.subtitle}</p>
      <div class="flex flex-wrap gap-3">
        <ButtonPrimary href="#contact">{messages.hero.ctaPrimary}</ButtonPrimary>
        <ButtonSecondary href="#process">{messages.hero.ctaSecondary}</ButtonSecondary>
      </div>
    </div>
    <div class="order-1 min-w-0 md:order-2">
      <HeroSystemDiagram messages={messages} />
    </div>
  </div>
</section>
