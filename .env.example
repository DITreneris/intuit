# Viešas kontaktinis el. paštas (`mailto:`); jei tuščia — naudojamas `finalCta.contactEmail` iš i18n
PUBLIC_CONTACT_EMAIL=nerijus@intuit.lt

# Kanoninis domenas (be repo kelio): OG, canonical, hreflang, sitemap
# Produkcija (custom domenas):
# PUBLIC_SITE_URL=https://www.intuit.lt

# GitHub Pages (deploy po subpath `/intuit`): žemiau + ASTRO_BASE
# PUBLIC_SITE_URL=https://ditreneris.github.io

# Astro `base` — GitHub Pages: /intuit (numatytasis be šių eilučių). Vercel — dažnai nebereikia:
# build automatiškai naudoja / (nebent subpath deploy).
# ASTRO_BASE=/intuit
# ASTRO_BASE=/

# Pasirinktinis alias (kai kuriais įrankiais); jei nustatytas, Astro gali naudoti vietoj PUBLIC_SITE_URL
# SITE_URL=https://ditreneris.github.io

# Vercel: paprastai užtenka be papildomų eilučių (žr. README). Custom domenas — PUBLIC_SITE_URL=https://…
