# Viešas kontaktinis el. paštas (`mailto:`); jei tuščia — naudojamas `finalCta.contactEmail` iš i18n
PUBLIC_CONTACT_EMAIL=nerijus@intuit.lt

# Kanoninis URL: OG, canonical, hreflang, ir build metu generuojamas /sitemap.xml
# Vercel: Settings → Environment Variables → Production (ir Preview, jei reikia)
# Be trailing slash
PUBLIC_SITE_URL=https://your-project.vercel.app

# Pasirinktinis alias (kai kuriais įrankiais); jei nustatytas, Astro gali naudoti vietoj PUBLIC_SITE_URL
# SITE_URL=https://your-project.vercel.app
