---
import ButtonPrimary from '../ui/ButtonPrimary.astro';
import ButtonSecondary from '../ui/ButtonSecondary.astro';
import type { SiteMessages } from '../../i18n/types';

interface Props {
  messages: SiteMessages;
}

const { messages } = Astro.props;

const tierIcons = [
  `<path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><line x1="4" y1="22" x2="4" y2="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>`,
  `<rect x="3" y="3" width="7" height="7" rx="1" fill="none" stroke="currentColor" stroke-width="2"/><rect x="14" y="3" width="7" height="7" rx="1" fill="none" stroke="currentColor" stroke-width="2"/><rect x="14" y="14" width="7" height="7" rx="1" fill="none" stroke="currentColor" stroke-width="2"/><rect x="3" y="14" width="7" height="7" rx="1" fill="none" stroke="currentColor" stroke-width="2"/>`,
  `<path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M23 6l-9.5 9.5-5-5L1 18M17 6h6v6"/>`,
] as const;
---

<section id="offers" class="scroll-mt-28 border-b border-line bg-surface">
  <div class="mx-auto max-w-content space-y-10 px-4 py-16 md:px-6 md:py-20">
    <div class="max-w-3xl space-y-4">
      <h2 class="text-3xl font-semibold tracking-tight md:text-4xl">{messages.offers.title}</h2>
      <p class="text-base text-muted md:text-lg">{messages.offers.subtitle}</p>
    </div>

    <div class="grid gap-6 md:grid-cols-3">
      {messages.offers.tiers.map((tier, idx) => (
        <article class:list={[tier.highlighted ? 'card-featured' : 'card flex flex-col p-6']}>
          <span
            class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl border border-accent/15 bg-accent/5 text-accent"
            aria-hidden="true"
          >
            <svg class="h-6 w-6" viewBox="0 0 24 24" set:html={tierIcons[idx] ?? tierIcons[0]} />
          </span>
          <div class="flex items-start justify-between gap-3">
            <div>
              <h3 class="text-xl font-semibold leading-snug">{tier.name}</h3>
              <p class="mt-1 text-sm font-medium text-muted">{tier.tag}</p>
            </div>
            <span class="shrink-0 rounded-full bg-paper px-2 py-1 text-xs font-semibold text-muted">{tier.price}</span>
          </div>
          <ul class="mt-6 flex-1 space-y-3 text-sm leading-relaxed">
            {tier.bullets.map((b) => (
              <li class="flex gap-2">
                <span class="mt-0.5 shrink-0 text-accent" aria-hidden="true">✓</span>
                <span>{b}</span>
              </li>
            ))}
          </ul>
          {tier.highlighted ? (
            <ButtonPrimary href="#contact" class="mt-8 w-full">
              {tier.cta}
            </ButtonPrimary>
          ) : (
            <ButtonSecondary
              href="#contact"
              class="mt-8 w-full hover:border-accent hover:text-accent"
            >
              {tier.cta}
            </ButtonSecondary>
          )}
        </article>
      ))}
    </div>
  </div>
</section>
