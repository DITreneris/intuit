---
/**
 * Du atskiri SVG (desktop / mobile) — bet koks mazgo keitimas turi būti atliktas abiejuose.
 * v5: kortelės SVG, jungtys — HTML overlay'us per .hsd-connectors (linija + chevron / line variant).
 *      Geometrija perskirstyta, kad tarp kortelių liktų realus 8 px „kvėpavimo“ tarpas (per 28 vnt. desktop, 24 vnt. mobile).
 *      Anchor karta („Žinutė“) lieka su tint + drop-shadow filtru, jokių filled triangle markerių.
 * Antraštė, caption ir kilpos etiketė — HTML (LT/EN iš messages.hero.diagram).
 */
import type { SiteMessages } from '../i18n/types';

interface Props {
  messages: SiteMessages;
  connectorVariant?: 'chevron' | 'line';
}

const { messages, connectorVariant = 'chevron' } = Astro.props;
const d = messages.hero.diagram;
---

<div
  class="hero-system-diagram relative min-h-[220px] overflow-visible rounded-xl border border-line/45 bg-paper px-4 py-5 transition-colors hover:border-accent/25 md:min-h-[300px] md:px-6 md:py-6"
  role="group"
  aria-labelledby="hero-diagram-strip"
  aria-describedby="hero-diagram-caption hero-diagram-loop-label hero-diagram-sr-desc"
>
  <p id="hero-diagram-sr-desc" class="sr-only">{d.svgDesc}</p>
  <div class="pointer-events-none absolute inset-0 rounded-xl bg-diagram-radial opacity-80 md:opacity-100" aria-hidden="true"></div>
  <div class="pointer-events-none absolute inset-0 hidden rounded-xl bg-diagram-glow md:block" aria-hidden="true"></div>

  <div class="relative z-10 mx-auto max-w-[620px] space-y-2 px-0 text-center">
    <p
      id="hero-diagram-strip"
      class="text-sm font-semibold uppercase tracking-[0.06em] text-ink md:text-base"
    >
      {d.systemStrip}
    </p>
    <p
      id="hero-diagram-caption"
      class="text-sm leading-snug text-muted md:leading-relaxed"
    >
      {d.diagramCaption}
    </p>
    <p
      id="hero-diagram-loop-label"
      class="inline-flex flex-wrap items-center justify-center gap-1.5 text-xs font-medium uppercase tracking-[0.12em] text-muted2"
    >
      <span class="text-accent/90" aria-hidden="true">↺</span>
      <span>{d.diagramLoopLabel}</span>
    </p>
  </div>

