---
/**
 * Inverse ženklas + raštas (`logo-pattern-inverse`) ant `bg-ink`.
 * Tekstai iš `messages.proof.*` (Hero vietoje buvusio Proof bloko).
 */
import type { SiteMessages } from '../i18n/types';

interface Props {
  messages: SiteMessages;
}

const { messages } = Astro.props;

const basePath = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<div class="overflow-hidden rounded-2xl bg-ink ring-1 ring-white/10">
  <p class="px-6 pb-4 pt-6 text-xs font-semibold uppercase tracking-[0.2em] text-paper/70 md:px-8 md:pt-8">
    {messages.proof.brandLabel}
  </p>
  <img
    src={`${basePath}brand/logo-pattern-inverse.jpg`}
    alt={messages.proof.brandPatternAlt}
    class="block h-auto w-full"
    width={1000}
    height={978}
    fetchpriority="high"
    loading="eager"
    decoding="async"
  />
</div>
