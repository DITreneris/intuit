<div
  class="hero-system-diagram relative min-h-[220px] overflow-visible rounded-xl border border-line/50 bg-paper px-4 py-5 shadow-soft ring-1 ring-line/30 transition-shadow hover:ring-accent/15 md:min-h-[300px] md:px-6 md:py-6"
  role="group"
  aria-labelledby="hero-diagram-strip"
  aria-describedby="hero-diagram-caption hero-diagram-loop-label hero-diagram-sr-desc"
>
  <p id="hero-diagram-sr-desc" class="sr-only">{d.svgDesc}</p>
  <div class="pointer-events-none absolute inset-0 rounded-xl bg-diagram-radial opacity-80 md:opacity-100" aria-hidden="true"></div>
  <div class="pointer-events-none absolute inset-0 hidden rounded-xl bg-diagram-glow md:block" aria-hidden="true"></div>

  <div class="relative z-10 mx-auto max-w-[620px] space-y-1.5 px-0 text-center">
    <p
      id="hero-diagram-strip"
      class="text-xs font-semibold uppercase tracking-[0.06em] text-ink md:text-2xs"
    >
      {d.systemStrip}
    </p>
    <p
      id="hero-diagram-caption"
      class="text-xs leading-snug text-muted md:text-2xs md:leading-relaxed"
    >
      {d.diagramCaption}
    </p>
    <p
      id="hero-diagram-loop-label"
      class="text-2xs font-medium uppercase tracking-[0.12em] text-muted2"
    >
      {d.diagramLoopLabel}
    </p>
