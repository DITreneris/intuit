---
import { Building2, Megaphone, Sparkles } from '@lucide/astro';
import type { SiteMessages } from '../../i18n/types';

interface Props {
  messages: SiteMessages;
}

const { messages } = Astro.props;

/** Stulpelių eiliškumas LT/EN sutampa — ikonos pagal indeksą (Lucide, @lucide/astro). */
const pillarIcons = [Building2, Megaphone, Sparkles] as const;
---

<section id="solution" class="relative scroll-mt-28 overflow-hidden border-b border-line bg-paper">
  <div
    class="pointer-events-none absolute inset-0 bg-diagram-glow bg-no-repeat opacity-40"
    aria-hidden="true"
  />
  <div class="section-shell relative space-y-10 md:space-y-12">
    <div class="max-w-measure space-y-4">
      <h2 class="text-3xl font-semibold tracking-tight md:text-4xl">{messages.solution.title}</h2>
      <div class="h-px w-12 bg-accent/20" aria-hidden="true"></div>
      <p class="section-intro">{messages.solution.intro}</p>
    </div>

    <div class="grid gap-6 md:grid-cols-3 md:items-stretch">
      {
        messages.solution.pillars.map((pillar, i) => {
          const Icon = pillarIcons[i];
          return (
            <article
              class="card card-brand flex h-full flex-col p-6 shadow-soft ring-1 ring-ink/[0.04] transition-[box-shadow,transform] duration-200 md:hover:-translate-y-0.5 md:hover:shadow-elevated"
            >
              <div
                class="mb-4 flex h-12 w-12 shrink-0 items-center justify-center rounded-xl border border-accent/15 bg-accent/[0.06] text-accent"
                aria-hidden="true"
              >
                {Icon ? <Icon size={24} stroke-width={2} class="shrink-0" /> : null}
              </div>
              <h3 class="card-title">{pillar.name}</h3>
              <p class="mt-2 text-sm font-semibold text-accent">{pillar.outcome}</p>
              <ul class="mt-4 space-y-2.5 text-base leading-relaxed text-ink">
                {pillar.points.map((p) => (
                  <li class="flex gap-2">
                    <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-accent" aria-hidden="true" />
                    <span>{p}</span>
                  </li>
                ))}
              </ul>
            </article>
          );
        })
      }
    </div>
  </div>
</section>
