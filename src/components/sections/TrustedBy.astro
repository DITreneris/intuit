---
import IntuitWordmark from '../IntuitWordmark.astro';
import type { SiteMessages } from '../../i18n/types';

interface Props {
  messages: SiteMessages;
}

const { messages } = Astro.props;
const t = messages.trustedBy;

const basePath = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<section
  id="clients"
  aria-labelledby="trusted-by-heading"
  class="scroll-mt-28 border-b border-line bg-paper"
>
  <div class="section-shell--tight">
    <div class="mb-6 text-center">
      <h2
        id="trusted-by-heading"
        class="label-eyebrow flex flex-wrap items-center justify-center gap-x-2 gap-y-1"
      >
        <span>{t.titleBefore}</span>
        <IntuitWordmark
          variant="light"
          alt={messages.hero.logoAlt}
          imgClass="h-10 w-auto shrink-0 md:h-11"
          loading="lazy"
        />
      </h2>
      <p class="mt-2 text-xs text-muted/90">{t.hint}</p>
    </div>

    <div class="relative">
      <div
        class="pointer-events-none absolute inset-y-0 left-0 z-10 w-8 bg-gradient-to-r from-paper to-transparent md:w-12"
        aria-hidden="true"
      />
      <div
        class="pointer-events-none absolute inset-y-0 right-0 z-10 w-8 bg-gradient-to-l from-paper to-transparent md:w-12"
        aria-hidden="true"
      />

      <div
        class="trusted-by-scroll flex snap-x snap-mandatory gap-4 overflow-x-auto overscroll-x-contain py-1 [-ms-overflow-style:none] [scrollbar-width:thin] md:gap-6 [&::-webkit-scrollbar]:h-1.5 [&::-webkit-scrollbar-thumb]:rounded-full [&::-webkit-scrollbar-thumb]:bg-line [&::-webkit-scrollbar-track]:bg-transparent"
        role="list"
        tabindex="0"
        aria-label={t.scrollAriaLabel}
      >
        {
          t.logos.map((logo) => (
            <div
              role="listitem"
              class="flex h-16 min-w-[10rem] shrink-0 snap-start items-center justify-center px-2 md:h-[4.5rem] md:min-w-[12rem] md:px-4"
            >
              <div class="flex h-12 w-full max-w-[11rem] items-center justify-center md:h-14 md:max-w-[13.5rem]">
                <img
                  src={`${basePath}${logo.src}`}
                  alt={logo.alt}
                  class="max-h-full max-w-full object-contain object-center"
                  width="220"
                  height="88"
                  loading="lazy"
                  decoding="async"
                />
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .trusted-by-scroll:focus-visible {
    outline: 2px solid theme('colors.accent');
    outline-offset: 4px;
    border-radius: 0.5rem;
  }
</style>
