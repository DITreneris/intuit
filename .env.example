# Viešas kontaktinis el. paštas (`mailto:`); jei tuščia — naudojamas `finalCta.contactEmail` iš i18n
PUBLIC_CONTACT_EMAIL=nerijus@intuit.lt

# Kanoninis domenas (be repo kelio): OG, canonical, hreflang, sitemap
# GitHub Pages (projektas intuit): žemiau + ASTRO_BASE
# PUBLIC_SITE_URL=https://ditreneris.github.io

# Astro `base` — GitHub Pages projektas: /intuit; Vercel šaknis: /
# ASTRO_BASE=/intuit
# ASTRO_BASE=/

# Pasirinktinis alias (kai kuriais įrankiais); jei nustatytas, Astro gali naudoti vietoj PUBLIC_SITE_URL
# SITE_URL=https://ditreneris.github.io

# Vėliau Vercel (šakninis deploy): PUBLIC_SITE_URL=https://<projektas>.vercel.app ir ASTRO_BASE=/
