---
import type { SiteMessages } from '../../i18n/types';

interface Props {
  messages: SiteMessages;
}

const { messages } = Astro.props;

/** Ikonos virš antraštės — 24×24, stroke */
const pillarIcons = [
  `<path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />`,
  `<path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M18 8A6 6 0 0 0 6 8c0 7-3 7-3 7h18s-3 0-3-7M13.73 21a2 2 0 0 1-3.46 0" />`,
  `<path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M4 8l8-3 8 3M4 12l8 3 8-3M4 16l8 3 8-3" />`,
] as const;
---

<section id="solution" class="scroll-mt-28 border-b border-line bg-paper">
  <div class="mx-auto max-w-content space-y-10 px-4 py-16 md:px-6 md:py-20">
    <div class="max-w-3xl space-y-4">
      <h2 class="text-3xl font-semibold tracking-tight md:text-4xl">{messages.solution.title}</h2>
      <p class="text-base text-muted md:text-lg">{messages.solution.intro}</p>
    </div>

    <div class="grid gap-6 md:grid-cols-3 md:items-stretch">
      {messages.solution.pillars.map((pillar, idx) => (
        <article class="card flex h-full flex-col p-6">
          <span
            class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl border border-accent/15 bg-accent/5 text-accent"
            aria-hidden="true"
          >
            <svg class="h-6 w-6" viewBox="0 0 24 24" set:html={pillarIcons[idx] ?? pillarIcons[0]} />
          </span>
          <h3 class="text-lg font-semibold leading-snug">{pillar.name}</h3>
          <p class="mt-2 text-sm font-semibold text-accentTeal">{pillar.outcome}</p>
          <ul class="mt-4 space-y-2 text-sm leading-relaxed text-ink">
            {pillar.points.map((p) => (
              <li class="flex gap-2">
                <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-accent" aria-hidden="true" />
                <span>{p}</span>
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>
