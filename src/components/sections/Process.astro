---
import type { SiteMessages } from '../../i18n/types';

interface Props {
  messages: SiteMessages;
}

const { messages } = Astro.props;

const stepIcons = [
  `<circle cx="11" cy="11" r="7" fill="none" stroke="currentColor" stroke-width="2"/><path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" d="M21 21l-4.2-4.2"/>`,
  `<path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h10M4 18h14"/>`,
  `<path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M12 5l7 7-7 7"/>`,
  `<path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M3 17l6-6 4 4 7-7M14 7h7v7"/>`,
] as const;
---

<section id="process" class="scroll-mt-28 border-b border-line bg-surface">
  <div class="mx-auto max-w-content space-y-10 px-4 py-16 md:px-6 md:py-20">
    <h2 class="text-3xl font-semibold tracking-tight md:text-4xl">{messages.process.title}</h2>

    <div class="relative grid gap-8 md:grid-cols-4 md:gap-6" role="list">
      <div
        class="pointer-events-none absolute left-0 right-0 top-[3.25rem] hidden h-px bg-gradient-to-r from-transparent via-accent/20 to-transparent md:block"
        aria-hidden="true"
      />
      {messages.process.steps.map((step, idx) => (
        <div class="card relative flex flex-col gap-4 border-accent/10 p-5 pt-6 shadow-softSm" role="listitem">
          <span
            class="flex h-12 w-12 items-center justify-center rounded-xl border border-accent/15 bg-accent/5 text-accent"
            aria-hidden="true"
          >
            <svg class="h-6 w-6" viewBox="0 0 24 24" set:html={stepIcons[idx] ?? stepIcons[0]} />
          </span>
          <div class="flex flex-wrap items-center gap-2">
            <span class="flex h-7 min-w-[1.75rem] items-center justify-center rounded-full bg-accent px-2 text-xs font-semibold text-white ring-2 ring-accent/15 ring-offset-2 ring-offset-surface">
              {idx + 1}
            </span>
            <h3 class="text-base font-semibold leading-snug">{step.name}</h3>
          </div>
          <p class="text-sm leading-relaxed text-muted">{step.detail}</p>
        </div>
      ))}
    </div>
  </div>
</section>
